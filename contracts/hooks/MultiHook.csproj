<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Neo.SmartContract.Framework" Version="3.8.1" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="MultiHook.cs" />
  </ItemGroup>

  <Target Name="CompileSmartContract" AfterTargets="Build">
    <Message Text="Compiling Neo smart contract: MultiHook.cs" Importance="high" />
    <Exec Command="nccs ./MultiHook.csproj -o ../bin/v3/hooks" WorkingDirectory="$(ProjectDir)" />
  </Target>

</Project>