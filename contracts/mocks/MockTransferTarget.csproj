<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Neo.SmartContract.Framework" Version="3.7.5" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="MockTransferTarget.cs" />
  </ItemGroup>

  <Target Name="CompileSmartContract" AfterTargets="Build">
    <Message Text="Compiling Neo smart contract: MockTransferTarget.cs" Importance="high" />
    <Exec Command="nccs ./MockTransferTarget.csproj -o ../bin/mocks" WorkingDirectory="$(ProjectDir)" />
  </Target>

</Project>
