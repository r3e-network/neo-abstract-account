# Copy to sdk/js/.env for live Neo N3 testnet validation.
# Use a funded disposable testnet account only.
TEST_WIF=replace-with-funded-testnet-wif
NEO_TESTNET_WIF=replace-with-funded-testnet-wif
PAYMASTER_TEST_WIF=replace-with-funded-testnet-wif
AA_RELAY_WIF=replace-with-funded-testnet-wif
TESTNET_RPC_URL=https://testnet1.neo.coz.io:443
NEO_RPC_URL=https://testnet1.neo.coz.io:443
VITE_AA_HASH_TESTNET=replace-with-40-byte-aa-script-hash
AA_CORE_HASH_TESTNET=replace-with-testnet-aa-core-hash
AA_WEB3AUTH_VERIFIER_HASH_TESTNET=replace-with-web3auth-verifier-hash
EXPECT_PROXY_SPEND_BLOCKED=1
REQUIRE_TESTNET_GAS=1
SKIP_TESTNET_READINESS_CHECK=0
MORPHEUS_ORACLE_HASH_TESTNET=replace-with-morpheus-oracle-script-hash
MORPHEUS_VERIFIER_PUBKEY_TESTNET=replace-with-morpheus-verifier-public-key
MORPHEUS_RUNTIME_URL=https://oracle.meshmini.app/testnet
MORPHEUS_TESTNET_RUNTIME_URL=https://oracle.meshmini.app/testnet
PHALA_API_URL=https://oracle.meshmini.app/testnet
PHALA_API_TOKEN=replace-with-runtime-token
PHALA_SHARED_SECRET=replace-with-runtime-token
