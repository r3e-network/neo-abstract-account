<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RunNccsAfterBuild>false</RunNccsAfterBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Neo.SmartContract.Framework" Version="3.8.1" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="PaymasterAuthority.cs" />
    <Compile Include="Paymaster.cs" />
  </ItemGroup>

  <Target Name="CompileSmartContract" AfterTargets="Build" Condition="'$(RunNccsAfterBuild)' == 'true'">
    <Message Text="Compiling Neo smart contract: Paymaster.cs" Importance="high" />
    <Exec Command="nccs ./Paymaster.csproj -o ../bin/v3/paymaster" WorkingDirectory="$(ProjectDir)" />
  </Target>

</Project>
