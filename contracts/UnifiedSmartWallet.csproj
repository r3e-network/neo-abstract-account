<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RunNccsAfterBuild>false</RunNccsAfterBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Neo.SmartContract.Framework" Version="3.8.1" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="UnifiedSmartWallet.cs" />
    <Compile Include="UnifiedSmartWallet.Models.cs" />
    <Compile Include="UnifiedSmartWallet.Internal.cs" />
    <Compile Include="UnifiedSmartWallet.Events.cs" />
    <Compile Include="UnifiedSmartWallet.Accounts.cs" />
    <Compile Include="UnifiedSmartWallet.State.cs" />
    <Compile Include="UnifiedSmartWallet.Execution.cs" />
    <Compile Include="UnifiedSmartWallet.VerifyContext.cs" />
    <Compile Include="UnifiedSmartWallet.Escape.cs" />
    <Compile Include="UnifiedSmartWallet.MarketEscrow.cs" />
    <Compile Include="UnifiedSmartWallet.Admin.cs" />
    <Compile Include="UnifiedSmartWallet.Paymaster.cs" />
  </ItemGroup>

  <Target Name="CompileSmartContract" AfterTargets="Build" Condition="'$(RunNccsAfterBuild)' == 'true'">
    <Message Text="Compiling Neo smart contract: UnifiedSmartWallet.cs" Importance="high" />
    <Exec Command="nccs ./UnifiedSmartWallet.csproj -o bin/v3" WorkingDirectory="$(ProjectDir)" />
  </Target>

</Project>
