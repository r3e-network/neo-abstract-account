{
  "name": "neo-abstract-account",
  "version": "1.0.0",
  "description": "Neo N3 Abstract Account SDK",
  "license": "MIT",
  "main": "src/index.js",
  "exports": "./src/index.js",
  "homepage": "https://github.com/r3e-network/neo-abstract-account",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r3e-network/neo-abstract-account.git"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "node --test tests/*.unit.test.js",
    "testnet:validate": "bash ./run_testnet_validation_suite.sh",
    "testnet:validate:dry-run": "bash ./run_testnet_validation_suite.sh --dry-run",
    "testnet:validate:threshold2": "node tests/aa_testnet_threshold2_validate.js",
    "testnet:validate:custom-verifier": "node tests/aa_testnet_custom_verifier_validate.js",
    "testnet:validate:dome-oracle": "node tests/aa_testnet_dome_oracle_validate.js",
    "testnet:validate:concurrency": "node tests/aa_testnet_concurrency_validate.js",
    "testnet:validate:approve-allowance": "node tests/aa_testnet_approve_allowance_validate.js",
    "testnet:validate:recovery": "node tests/recovery_testnet_validate.js",
    "test:recovery:logic": "node tests/recovery_verifier_logic_test.js",
    "testnet:validate:recovery:safe": "node tests/recovery_testnet_validate_safe.js",
    "testnet:validate:recovery:loopring": "node tests/recovery_testnet_validate_loopring.js",
    "testnet:validate:recovery:all": "npm run testnet:validate:recovery && npm run testnet:validate:recovery:safe && npm run testnet:validate:recovery:loopring"
  },
  "dependencies": {
    "@cityofzion/neon-js": "^5.4.0",
    "ethers": "^6.11.1"
  }
}
